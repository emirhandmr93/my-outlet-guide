rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isOptionalStringOrNull(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function isValidRating(value) {
      return value is number && value >= 1 && value <= 5;
    }

    function hasValidReviewCategoryRatings(data) {
      return data.categoryRatings is map
        && data.categoryRatings.keys().hasOnly(['transportation', 'brands', 'restaurants', 'services'])
        && data.categoryRatings.keys().hasAll(['transportation', 'brands', 'restaurants', 'services'])
        && isValidRating(data.categoryRatings.transportation)
        && isValidRating(data.categoryRatings.brands)
        && isValidRating(data.categoryRatings.restaurants)
        && isValidRating(data.categoryRatings.services);
    }

    function hasValidReviewContent(data) {
      return isValidRating(data.rating)
        && isValidRating(data.overallRating)
        && hasValidReviewCategoryRatings(data)
        && data.comment is string
        && data.comment.size() <= 4000
        && data.title is string
        && data.title.size() <= 120
        && isNonEmptyString(data.userDisplayName)
        && data.userDisplayName.size() <= 120;
    }

    function hasValidReviewCreateData(outletId, reviewId) {
      return request.resource.data.keys().hasOnly([
          'reviewId',
          'outletId',
          'userId',
          'userDisplayName',
          'rating',
          'overallRating',
          'categoryRatings',
          'title',
          'comment',
          'createdAt',
          'updatedAt',
          'status'
        ])
        && request.resource.data.reviewId == reviewId
        && request.resource.data.outletId == outletId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'published'
        && hasValidReviewContent(request.resource.data);
    }

    function keepsReviewOwnership(outletId, reviewId) {
      return request.resource.data.reviewId == resource.data.reviewId
        && request.resource.data.reviewId == reviewId
        && request.resource.data.outletId == resource.data.outletId
        && request.resource.data.outletId == outletId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.userId == request.auth.uid;
    }

    function hasValidReviewUpdateData() {
      return request.resource.data.keys().hasOnly([
          'reviewId',
          'outletId',
          'userId',
          'userDisplayName',
          'rating',
          'overallRating',
          'categoryRatings',
          'title',
          'comment',
          'createdAt',
          'updatedAt',
          'status',
          'deletedAt',
          'previousComment',
          'previousTitle',
          'previousRating',
          'previousCategoryRatings',
          'editedAt',
          'editCount'
        ]);
    }

    function hasValidOptionalPreviousCategoryRatings(data) {
      return !('previousCategoryRatings' in data) || (
        data.previousCategoryRatings is map
        && data.previousCategoryRatings.keys().hasOnly(['transportation', 'brands', 'restaurants', 'services'])
        && data.previousCategoryRatings.keys().hasAll(['transportation', 'brands', 'restaurants', 'services'])
        && isValidRating(data.previousCategoryRatings.transportation)
        && isValidRating(data.previousCategoryRatings.brands)
        && isValidRating(data.previousCategoryRatings.restaurants)
        && isValidRating(data.previousCategoryRatings.services)
      );
    }

    function hasValidReviewEditMetadata(data) {
      return (!('previousComment' in data) || (data.previousComment is string && data.previousComment.size() <= 4000))
        && (!('previousTitle' in data) || (data.previousTitle is string && data.previousTitle.size() <= 120))
        && (!('previousRating' in data) || isValidRating(data.previousRating))
        && hasValidOptionalPreviousCategoryRatings(data)
        && (!('editedAt' in data) || data.editedAt is timestamp)
        && (!('editCount' in data) || (data.editCount is number && data.editCount >= 1));
    }

    function isPublishedReviewUpdate() {
      return request.resource.data.status == 'published'
        && !('deletedAt' in request.resource.data)
        && hasValidReviewContent(request.resource.data);
    }

    function isSoftDeleteReviewUpdate() {
      return request.resource.data.status == 'deleted'
        && request.resource.data.deletedAt is string
        && request.resource.data.deletedAt.size() > 0
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedAt.size() > 0;
    }

    function isValidHelpfulCreate(outletId, reviewId, userId) {
      return request.resource.data.keys().hasOnly(['userId', 'createdAt'])
        && userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && exists(/databases/$(database)/documents/reviews/$(outletId)/items/$(reviewId))
        && get(/databases/$(database)/documents/reviews/$(outletId)/items/$(reviewId)).data.userId != request.auth.uid;
    }


    function isOwnerDocument(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasValidFavoritesData() {
      return request.resource.data.keys().hasOnly(['favoriteIds'])
        && request.resource.data.favoriteIds is list;
    }

    function hasValidFlightDealPreferencesData(userId) {
      return request.resource.data.keys().hasOnly([
          'departureAirportId',
          'selectedCityIds',
          'selectedThresholds'
        ])
        && userId == request.auth.uid
        && isNonEmptyString(request.resource.data.departureAirportId)
        && request.resource.data.selectedCityIds is list
        && request.resource.data.selectedThresholds is list;
    }

    function isValidReviewReportCreate() {
      return request.resource.data.keys().hasOnly([
          'reportId',
          'outletId',
          'reviewId',
          'reporterUserId',
          'reason',
          'createdAt',
          'status',
          'firestoreCreatedAt'
        ])
        && isNonEmptyString(request.resource.data.reportId)
        && isNonEmptyString(request.resource.data.outletId)
        && isNonEmptyString(request.resource.data.reviewId)
        && request.resource.data.reporterUserId == request.auth.uid
        && request.resource.data.reason in ['spam', 'abuse', 'off_topic', 'other']
        && request.resource.data.status == 'open';
    }



    function hasValidNotificationSettingsData(userId) {
      return request.resource.data.keys().hasOnly([
          'userId',
          'enabled',
          'tripRemindersEnabled',
          'favoriteOutletUpdatesEnabled',
          'reviewUpdatesEnabled',
          'marketingEnabled',
          'updatedAt',
          'firestoreUpdatedAt',
          'disabledAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && userId == request.auth.uid
        && request.resource.data.enabled is bool
        && request.resource.data.tripRemindersEnabled is bool
        && request.resource.data.favoriteOutletUpdatesEnabled is bool
        && request.resource.data.reviewUpdatesEnabled is bool
        && request.resource.data.marketingEnabled is bool
        && isNonEmptyString(request.resource.data.updatedAt)
        && (request.resource.data.disabledAt == null || isNonEmptyString(request.resource.data.disabledAt));
    }
    function hasValidNotificationTokenData(userId) {
      return request.resource.data.keys().hasOnly([
          'userId',
          'token',
          'platform',
          'createdAt',
          'updatedAt',
          'disabledAt',
          'firestoreCreatedAt',
          'firestoreUpdatedAt'
        ])
        && userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && isNonEmptyString(request.resource.data.token)
        && request.resource.data.token.size() <= 512
        && request.resource.data.platform in ['ios', 'android', 'web', 'windows', 'macos']
        && isNonEmptyString(request.resource.data.createdAt)
        && isNonEmptyString(request.resource.data.updatedAt)
        && (request.resource.data.disabledAt == null || isNonEmptyString(request.resource.data.disabledAt));
    }

    function keepsNotificationTokenOwnership(userId) {
      return userId == request.auth.uid
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.token == resource.data.token
        && request.resource.data.platform == resource.data.platform
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function hasValidTripData(userId, tripId) {
      return request.resource.data.keys().hasOnly([
          'tripId',
          'userId',
          'outletId',
          'outletName',
          'tripName',
          'destination',
          'country',
          'city',
          'visitDate',
          'travelerCount',
          'notes',
          'status',
          'createdAt',
          'updatedAt',
          'firestoreCreatedAt',
          'firestoreUpdatedAt',
          'startDate',
          'endDate',
          'segments',
          'flightDetails',
          'reminderPlan'
        ])
        && request.resource.data.userId == request.auth.uid
        && userId == request.auth.uid
        && (request.resource.data.tripId == tripId || request.resource.data.tripId == null)
        && isOptionalStringOrNull(request.resource.data.outletId, 160)
        && isOptionalStringOrNull(request.resource.data.outletName, 240)
        && isNonEmptyString(request.resource.data.tripName)
        && request.resource.data.tripName.size() <= 240
        && isOptionalStringOrNull(request.resource.data.destination, 240)
        && isOptionalStringOrNull(request.resource.data.country, 120)
        && isOptionalStringOrNull(request.resource.data.city, 120)
        && isOptionalStringOrNull(request.resource.data.visitDate, 40)
        && (request.resource.data.travelerCount == null || (request.resource.data.travelerCount is number && request.resource.data.travelerCount >= 1 && request.resource.data.travelerCount <= 50))
        && isOptionalStringOrNull(request.resource.data.notes, 2000)
        && request.resource.data.status in ['upcoming', 'active', 'past']
        && isOptionalStringOrNull(request.resource.data.startDate, 40)
        && isOptionalStringOrNull(request.resource.data.endDate, 40)
        && request.resource.data.segments is list
        && (request.resource.data.flightDetails == null || request.resource.data.flightDetails is map)
        && request.resource.data.reminderPlan is list
        && isNonEmptyString(request.resource.data.createdAt)
        && isNonEmptyString(request.resource.data.updatedAt);
    }

    function keepsTripOwnership(userId, tripId) {
      return resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.tripId == tripId
        && userId == request.auth.uid;
    }

    match /favorites/{userId} {
      allow read: if isOwnerDocument(userId);
      allow create, update: if isOwnerDocument(userId) && hasValidFavoritesData();
      allow delete: if isOwnerDocument(userId);
    }

    match /flightDealPreferences/{userId} {
      allow read: if isOwnerDocument(userId);
      allow create, update: if isSignedIn() && hasValidFlightDealPreferencesData(userId);
      allow delete: if isOwnerDocument(userId);
    }

    match /reviews/{outletId}/items/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && reviewId == request.auth.uid
        && hasValidReviewCreateData(outletId, reviewId);
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && keepsReviewOwnership(outletId, reviewId)
        && hasValidReviewUpdateData()
        && hasValidReviewEditMetadata(request.resource.data)
        && (isPublishedReviewUpdate() || isSoftDeleteReviewUpdate());
      allow delete: if false;

      match /helpful/{userId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidHelpfulCreate(outletId, reviewId, userId);
        allow delete: if isSignedIn() && userId == request.auth.uid && resource.data.userId == request.auth.uid;
        allow update: if false;
      }
    }


    match /userTrips/{userId}/items/{tripId} {
      allow read: if isOwnerDocument(userId);
      allow create: if isSignedIn() && hasValidTripData(userId, tripId);
      allow update: if isSignedIn() && keepsTripOwnership(userId, tripId) && hasValidTripData(userId, tripId);
      allow delete: if isSignedIn() && userId == request.auth.uid && resource.data.userId == request.auth.uid;
    }


    match /userNotificationSettings/{userId} {
      allow read: if isOwnerDocument(userId);
      allow create, update: if isSignedIn() && hasValidNotificationSettingsData(userId);
      allow delete: if isOwnerDocument(userId);

      match /tokens/{tokenId} {
        allow read: if isOwnerDocument(userId);
        allow create: if isSignedIn() && hasValidNotificationTokenData(userId);
        allow update: if isSignedIn()
          && keepsNotificationTokenOwnership(userId)
          && hasValidNotificationTokenData(userId);
        allow delete: if isOwnerDocument(userId);
      }
    }

    match /notificationDeliveries/{deliveryId} {
      allow read, write: if false;
    }

    match /reviewReports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reportId == reportId
        && isValidReviewReportCreate();
      allow read, update, delete: if false;
    }
  }
}
